// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// --- ENUMS ---

enum ClassroomRole {
  owner
  admin
  member

  @@map("classroom_role")
}

enum CourseVisibility {
  public
  private
  sale

  @@map("course_visibility")
}

enum ContentType {
  video_embed
  file_docx
  file_pdf
  image_png
  image_jpg
  text_content

  @@map("content_type")
}

enum ConversationType {
  classroom_common
  private_direct
  custom_group

  @@map("conversation_type")
}

// --- MODELS ---

model User {
  id               String   @id @default(uuid()) 
  email            String   @unique
  passwordHash     String   @map("password_hash")
  fullName         String?  @map("full_name")
  avatarUrl        String?  @map("avatar_url")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  classroomMembers    ClassroomMember[]
  classroomJoinRequests ClassroomJoinRequest[]
  ownedCourses        Course[]             @relation("CourseOwner")
  courseMembers       CourseMember[]
  courseInvitations   CourseInvitation[]
  progresses          UserProgress[]
  conversationMembers ConversationMember[]
  messages            Message[]            @relation("MessageSender")
  createdTasks        ClassroomTask[]      @relation("TaskCreator")
  taskSubmissions     TaskSubmission[]     @relation("TaskStudent")
  notes               Note[]
  createdCalls        Call[]               @relation("CallCreator")

  @@map("users")
}

model Classroom {
  id          String   @id @default(uuid()) 
  title       String
  description String?  @db.Text
  inviteCode  String?  @unique @map("invite_code")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  members       ClassroomMember[]
  joinRequests  ClassroomJoinRequest[]
  conversations Conversation[]
  tasks         ClassroomTask[]
  linkedCourses ClassroomLinkedCourse[]
  notes         Note[]

  @@map("classrooms")
}

model ClassroomMember {
  id          String        @id @default(uuid()) 
  classroomId String        @map("classroom_id") 
  userId      String        @map("user_id") 
  role        ClassroomRole @default(member)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  classroom   Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@map("classroom_members")
}

model ClassroomJoinRequest {
  id          String   @id @default(uuid()) 
  classroomId String   @map("classroom_id") 
  userId      String   @map("user_id") 
  createdAt   DateTime @default(now()) @map("created_at")

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@map("classroom_join_requests")
}

model Course {
  id           String           @id @default(uuid()) 
  ownerId      String           @map("owner_id") 
  title        String
  description  String?          @db.Text
  thumbnailUrl String?          @map("thumbnail_url")
  price        Decimal          @default(0) @db.Decimal
  visibility   CourseVisibility @default(public)
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  owner            User                    @relation("CourseOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members          CourseMember[]
  invitations      CourseInvitation[]
  sections         Section[]
  linkedClassrooms ClassroomLinkedCourse[]

  @@map("courses")
}

model CourseMember {
  id         String   @id @default(uuid()) 
  courseId   String   @map("course_id") 
  userId     String   @map("user_id") 
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@map("course_members")
}

model CourseInvitation {
  id        String   @id @default(uuid()) 
  courseId  String   @map("course_id") 
  userId    String   @map("user_id") 
  invitedAt DateTime @default(now()) @map("invited_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("course_invitations")
}

model Section {
  id         String   @id @default(uuid()) 
  courseId   String   @map("course_id") 
  title      String?
  orderIndex Int?     @map("order_index")

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  @@map("sections")
}

model Lesson {
  id         String       @id @default(uuid()) 
  sectionId  String       @map("section_id") 
  title      String?
  type       ContentType?
  contentUrl String?      @map("content_url")
  rawText    String?      @db.Text @map("raw_text")
  orderIndex Int?         @map("order_index")

  section    Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progresses UserProgress[]
  notes      Note[]

  @@map("lessons")
}

model UserProgress {
  id                String   @id @default(uuid()) 
  userId            String   @map("user_id") 
  lessonId          String   @map("lesson_id") 
  lastWatchedSecond Int      @default(0) @map("last_watched_second")
  isCompleted       Boolean  @default(false) @map("is_completed")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson            Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

model Conversation {
  id          String            @id @default(uuid()) 
  classroomId String?           @map("classroom_id") 
  type        ConversationType?
  title       String?
  createdAt   DateTime          @default(now()) @map("created_at")

  classroom   Classroom?        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  members     ConversationMember[]
  messages    Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(uuid()) 
  conversationId String       @map("conversation_id") 
  userId         String       @map("user_id") 
  joinedAt       DateTime     @default(now()) @map("joined_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversation_members")
}

model Message {
  id             String       @id @default(uuid()) 
  conversationId String       @map("conversation_id") 
  senderId       String       @map("sender_id") 
  content        String?      @db.Text
  fileUrl        String?      @map("file_url")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  @@map("messages")
}

model ClassroomTask {
  id          String    @id @default(uuid()) 
  classroomId String    @map("classroom_id") 
  creatorId   String    @map("creator_id") 
  title       String?
  description String?   @db.Text
  deadline    DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  submissions TaskSubmission[]

  @@map("classroom_tasks")
}

model TaskSubmission {
  id          String        @id @default(uuid()) 
  taskId      String        @map("task_id") 
  studentId   String        @map("student_id") 
  content     String?       @db.Text
  fileUrl     String?       @map("file_url")
  submittedAt DateTime      @default(now()) @map("submitted_at")
  grade       Decimal?      @db.Decimal

  task        ClassroomTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student     User          @relation("TaskStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("task_submissions")
}

model ClassroomLinkedCourse {
  classroomId String    @map("classroom_id") 
  courseId    String    @map("course_id") 

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([classroomId, courseId])
  @@map("classroom_linked_courses")
}

model Note {
  id             String     @id @default(uuid()) 
  userId         String     @map("user_id") 
  lessonId       String     @map("lesson_id") 
  classroomId    String?    @map("classroom_id") 
  content        String     @db.Text
  videoTimestamp Int?       @map("video_timestamp")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  classroom      Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([userId, classroomId])
  @@map("notes")
}

model Call {
  id               String    @id @default(uuid())
  creatorId        String    @map("creator_id")
  title            String?   @db.VarChar(255)
  status           String    @default("ongoing") @db.VarChar(50)
  participantCount Int       @default(0) @map("participant_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  endedAt          DateTime? @map("ended_at")

  creator          User      @relation("CallCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([status]) // Đánh index để truy vấn nhanh các phòng đang "ongoing"
  @@map("calls")
}
